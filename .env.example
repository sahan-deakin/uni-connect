# Copy this file to .env and fill in values before running.
# The application works with defaults but JWT_SECRET should be changed for production.

# JWT signing secret — change this to a long random string in production
JWT_SECRET=uniconnect-dev-secret

# MongoDB connection string (overridden by docker-compose automatically)
# MONGO_URI=mongodb://mongo:27017/uni-connect

# Application port (default: 3000)
# PORT=3000
